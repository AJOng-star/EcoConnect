{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in EcoConnect",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "bio": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isPersonOfMonth": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "xp", "level"]
    },
    "Post": {
      "title": "Post",
      "description": "A social update shared by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "integer" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "content", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "Monthly inspirational article by admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "publishedAt"]
    },
    "Gift": {
      "title": "Gift",
      "description": "A gift sent from one user to another",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["xp", "comment"] },
        "value": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "type", "value", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "posts": {
      "schema": "Post",
      "description": "Social updates"
    },
    "posts/{postId}/comments": {
      "schema": "Comment",
      "description": "Comments on specific posts"
    },
    "articles": {
      "schema": "Article",
      "description": "Monthly admin articles"
    },
    "gifts": {
      "schema": "Gift",
      "description": "Sent gifts"
    }
  }
}
